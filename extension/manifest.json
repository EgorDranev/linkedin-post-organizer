{
  "manifest_version": 3,
  "name": "LinkedIn Saver",
  "version": "0.3.0",
  "description": "Automatically save LinkedIn posts to your LinkedIn Saver app when you bookmark them.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://linkedin-saver.vercel.app/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": [
        "lib/chrome-safe.js",
        "lib/extract.js",
        "lib/save.js",
        "native-save.js",
        "import-saved.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LinkedIn Saver",
    "default_popup": "popup.html"
  }
}
