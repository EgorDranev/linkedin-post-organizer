{
  "manifest_version": 3,
  "name": "LinkedIn Saver",
  "version": "0.1.0",
  "description": "Save LinkedIn posts to your local LinkedIn Saver app and get suggested tags.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LinkedIn Saver",
    "default_popup": "popup.html"
  }
}
