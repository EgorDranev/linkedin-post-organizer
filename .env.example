# Postgres connection string (Neon, via Vercel Marketplace or neon.tech).
# Vercel injects POSTGRES_URL automatically when you connect a Neon store;
# DATABASE_URL also works. For local `vercel dev`, run `vercel env pull`.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AI tagging / summaries / theme clustering (Anthropic Claude).
# Optional: when unset, the app falls back to the offline heuristics and works
# exactly as before. Set this to turn on AI-powered intelligence.
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-haiku-4-5-20251001).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
