# Postgres connection string (Neon, via Vercel Marketplace or neon.tech).
# Vercel injects POSTGRES_URL automatically when you connect a Neon store;
# DATABASE_URL also works. For local `vercel dev`, run `vercel env pull`.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AI tagging / summaries / theme clustering (Anthropic Claude).
# Optional: when unset, the app falls back to the offline heuristics and works
# exactly as before. Set this to turn on AI-powered intelligence.
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-haiku-4-5-20251001).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Clerk application configured with email verification links only.
# Example placeholders only. Put real keys in .env.local or Vercel, never Git.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_linkedin_saver_local
CLERK_PUBLISHABLE_KEY=pk_test_linkedin_saver_local
CLERK_SECRET_KEY=sk_test_linkedin_saver_local
APP_ORIGIN=http://localhost:3000

# Example Clerk user id that receives pre-account records during migration.
FOUNDER_USER_ID=user_founder
